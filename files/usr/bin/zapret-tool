#!/bin/sh
set -eu

CONF="${ZTOOL_CONF:-/etc/config/zapret}"
BACKUP="${ZTOOL_BACKUP:-/etc/config/zapret.ztool.bak}"
IPSET_DIR="${ZTOOL_IPSET_DIR:-/opt/zapret/ipset}"
FAKE_DIR="${ZTOOL_FAKE_DIR:-/opt/zapret/files/fake}"
INIT="${ZTOOL_INIT:-/etc/init.d/zapret}"
DNSMASQ_INIT="${ZTOOL_DNSMASQ_INIT:-/etc/init.d/dnsmasq}"
SYNC_CONFIG="${ZTOOL_SYNC_CONFIG:-/opt/zapret/sync_config.sh}"
AUTO_FILE="$IPSET_DIR/zapret-hosts-auto.txt"
USER_HOSTS="$IPSET_DIR/zapret-hosts-user.txt"
EXCLUDE_FILE="$IPSET_DIR/zapret-hosts-user-exclude.txt"
GOOGLE_HOSTS="$IPSET_DIR/zapret-hosts-google.txt"
TMP_ROOT="${ZTOOL_TMP_DIR:-/tmp}"
HOSTS_FILE="${ZTOOL_HOSTS_FILE:-/etc/hosts}"
EXCLUDE_URL="${ZTOOL_EXCLUDE_URL:-https://raw.githubusercontent.com/StressOzz/Zapret-Manager/refs/heads/main/zapret-hosts-user-exclude.txt}"
FLOWSEAL_BASE="${ZTOOL_FLOWSEAL_BASE:-https://raw.githubusercontent.com/Flowseal/zapret-discord-youtube/main}"
FLOWSEAL_GENERAL="$IPSET_DIR/flowseal-general.txt"
FLOWSEAL_GOOGLE="$IPSET_DIR/flowseal-google.txt"
FLOWSEAL_EXCLUDE="$IPSET_DIR/flowseal-exclude.txt"
FLOWSEAL_HOSTS="$IPSET_DIR/flowseal-hosts.txt"
TELEGRAM_HOSTS="$IPSET_DIR/zapret-hosts-telegram.txt"
DISCORD_MEDIA_HOSTS="$IPSET_DIR/zapret-hosts-discord-media.txt"
FLOWSEAL_TMP_DIR="$TMP_ROOT/zapret-flowseal"
FLOWSEAL_IPSET="$FLOWSEAL_TMP_DIR/ipset-service.txt"
FLOWSEAL_TARGETS="$FLOWSEAL_TMP_DIR/targets.txt"
FLOWSEAL_META="$IPSET_DIR/flowseal-meta.txt"
FLOWSEAL_DBCLOUD_FAKE="$FAKE_DIR/quic_initial_dbankcloud_ru.bin"
TCP_PORTS="80,443,2053,2083,2087,2096,8443"
UDP_PORTS="443,19294-19344,50000-50100"

die() {
	echo "ERROR: $*" >&2
	exit 1
}

have() {
	command -v "$1" >/dev/null 2>&1
}

use_uci() {
	[ "${ZTOOL_NO_UCI:-0}" != "1" ] && [ "$CONF" = "/etc/config/zapret" ] && have uci
}

need_conf() {
	[ -f "$CONF" ] || die "zapret config not found: $CONF"
}

tmp_file() {
	echo "/tmp/zapret-tool.$$.$1"
}

restart_zapret() {
	[ "${ZTOOL_NO_RESTART:-0}" = "1" ] && return 0
	if [ -x "$SYNC_CONFIG" ]; then
		"$SYNC_CONFIG"
	fi
	[ -x "$INIT" ] || die "init script is not executable: $INIT"
	"$INIT" restart
}

restart_dnsmasq() {
	[ "${ZTOOL_NO_RESTART:-0}" = "1" ] && return 0
	[ -x "$DNSMASQ_INIT" ] || return 0
	"$DNSMASQ_INIT" restart
}

backup_config() {
	need_conf
	cp "$CONF" "$BACKUP"
	echo "Backup saved: $BACKUP"
}

restore_config() {
	[ -f "$BACKUP" ] || die "backup not found: $BACKUP"
	cp "$BACKUP" "$CONF"
	restart_zapret
	echo "Config restored from: $BACKUP"
}

replace_option_file() {
	key="$1"
	value="$2"
	tmp="$(tmp_file conf)"
	start="$(grep -n "^[[:space:]]*option[[:space:]][[:space:]]*$key[[:space:]]*'" "$CONF" | head -n 1 | cut -d: -f1 || true)"

	if [ -z "$start" ]; then
		cp "$CONF" "$tmp"
		{
			printf "\toption %s '\n" "$key"
			printf "%s\n" "$value"
			printf "'\n"
		} >> "$tmp"
	else
		next=$((start + 1))
		rel_end="$(tail -n +"$next" "$CONF" | grep -n "^[[:space:]]*'[[:space:]]*$" | head -n 1 | cut -d: -f1 || true)"
		if [ -n "$rel_end" ]; then
			end=$((start + rel_end))
		else
			end="$start"
		fi

		if [ "$start" -gt 1 ]; then
			sed -n "1,$((start - 1))p" "$CONF" > "$tmp"
		else
			: > "$tmp"
		fi
		{
			printf "\toption %s '\n" "$key"
			printf "%s\n" "$value"
			printf "'\n"
		} >> "$tmp"
		total="$(wc -l < "$CONF" | tr -d ' ')"
		if [ "$end" -lt "$total" ]; then
			sed -n "$((end + 1)),\$p" "$CONF" >> "$tmp"
		fi
	fi

	cp "$tmp" "$CONF"
	rm -f "$tmp"
}

replace_simple_file() {
	key="$1"
	value="$2"
	tmp="$(tmp_file simple)"
	awk -v key="$key" -v value="$value" '
		$1 == "option" && $2 == key {
			print "\toption " key " \047" value "\047"
			done = 1
			next
		}
		{ print }
		END {
			if (!done) print "\toption " key " \047" value "\047"
		}
	' "$CONF" > "$tmp"
	cp "$tmp" "$CONF"
	rm -f "$tmp"
}

set_option() {
	key="$1"
	value="$2"
	if use_uci; then
		uci -q set "zapret.config.$key=$value" && uci -q commit zapret && return 0
	fi
	replace_simple_file "$key" "$value"
}

set_nfqws_opt() {
	value="$1"
	if use_uci; then
		uci -q set "zapret.config.NFQWS_OPT=$value" && uci -q commit zapret && return 0
	fi
	replace_option_file "NFQWS_OPT" "$value"
}

get_option_file() {
	key="$1"
	awk -v key="$key" '$1 == "option" && $2 == key {
		gsub(/^'\''|'\''$/, "", $3)
		print $3
		exit
	}' "$CONF"
}

get_option() {
	key="$1"
	if use_uci; then
		uci -q get "zapret.config.$key" 2>/dev/null || true
	else
		get_option_file "$key"
	fi
}

current_nfqws_opt() {
	need_conf
	if use_uci; then
		uci -q get zapret.config.NFQWS_OPT 2>/dev/null || true
		return
	fi
	start="$(grep -n "^[[:space:]]*option[[:space:]][[:space:]]*NFQWS_OPT[[:space:]]*'" "$CONF" | head -n 1 | cut -d: -f1 || true)"
	[ -n "$start" ] || return 0
	next=$((start + 1))
	tail -n +"$next" "$CONF" | sed "/^[[:space:]]*'[[:space:]]*$/q" | sed '$d'
}

ensure_ports() {
	set_option NFQWS_PORTS_TCP "$TCP_PORTS"
	set_option NFQWS_PORTS_UDP "$UDP_PORTS"
}

discord_blocks() {
	cat <<EOF
--new
--filter-udp=19294-19344,50000-50100
--filter-l7=discord,stun
--dpi-desync=fake
--dpi-desync-fake-discord=$FAKE_DIR/stun.bin
--dpi-desync-fake-stun=$FAKE_DIR/stun.bin
--dpi-desync-repeats=6
--new
--filter-tcp=2053,2083,2087,2096,8443
--hostlist-domains=discord.media
--dpi-desync=multisplit
--dpi-desync-split-seqovl=652
--dpi-desync-split-pos=2
--dpi-desync-split-seqovl-pattern=$FAKE_DIR/tls_clienthello_www_google_com.bin
EOF
}

