strategy_fs_general() {
	flowseal_upstream_strategy fs-general general
}

strategy_fs_alt() {
	flowseal_upstream_strategy fs-alt alt01
}

strategy_fs_simple_fake() {
	flowseal_upstream_strategy fs-simple-fake simple
}

strategy_fs_fake_tls_auto() {
	flowseal_upstream_strategy fs-fake-tls-auto fake-tls-auto
}

strategy_fs_general_ipset() {
	cat <<EOF
--comment=ZTOOL_fs-general-ipset
$(strategy_fs_general)
--new
--filter-udp=443
--ipset=$FLOWSEAL_IPSET
--hostlist-exclude=$FLOWSEAL_EXCLUDE
--hostlist-exclude=$EXCLUDE_FILE
--dpi-desync=fake
--dpi-desync-repeats=6
--dpi-desync-fake-quic=$FAKE_DIR/quic_initial_www_google_com.bin
--new
--filter-tcp=80,443,8443
--ipset=$FLOWSEAL_IPSET
--hostlist-exclude=$FLOWSEAL_EXCLUDE
--hostlist-exclude=$EXCLUDE_FILE
--dpi-desync=multisplit
--dpi-desync-split-seqovl=568
--dpi-desync-split-pos=1
--dpi-desync-split-seqovl-pattern=$FAKE_DIR/4pda.bin
EOF
	return 0
}

