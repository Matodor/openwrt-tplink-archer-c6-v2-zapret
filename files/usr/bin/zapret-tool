flowseal_common_hosts() {
	cat <<EOF
--hostlist=$FLOWSEAL_GENERAL
--hostlist=$USER_HOSTS
--hostlist=$TELEGRAM_HOSTS
--hostlist-exclude=$FLOWSEAL_EXCLUDE
--hostlist-exclude=$EXCLUDE_FILE
EOF
}

flowseal_discord_blocks() {
	cat <<EOF
--new
--filter-udp=19294-19344,50000-50100
--filter-l7=discord,stun
--dpi-desync=fake
--dpi-desync-fake-discord=$FLOWSEAL_DBCLOUD_FAKE
--dpi-desync-fake-stun=$FLOWSEAL_DBCLOUD_FAKE
--dpi-desync-repeats=6
--new
--filter-tcp=2053,2083,2087,2096,8443
--hostlist-domains=discord.media
--dpi-desync=multisplit
--dpi-desync-split-seqovl=681
--dpi-desync-split-pos=1
--dpi-desync-split-seqovl-pattern=$FAKE_DIR/tls_clienthello_www_google_com.bin
EOF
}

flowseal_discord_udp_block() {
	mode="$1"
	repeats=6
	extra_fake=""
	if [ "$mode" = "alt12" ]; then
		repeats=3
		extra_fake="--dpi-desync-fake-discord=$FAKE_DIR/stun.bin"
	fi
	cat <<EOF
--new
--filter-udp=19294-19344,50000-50100
--filter-l7=discord,stun
--dpi-desync=fake
$extra_fake
--dpi-desync-fake-discord=$FLOWSEAL_DBCLOUD_FAKE
--dpi-desync-fake-stun=$FLOWSEAL_DBCLOUD_FAKE
--dpi-desync-repeats=$repeats
EOF
}

flowseal_emit_variant() {
	label="$1"
	udp_repeats="$2"
	discord_udp_mode="$3"
	discord_opts="$4"
	google_opts="$5"
	general_opts="$6"
	cat <<EOF
--comment=ZTOOL_$label
--filter-udp=443
--hostlist=$FLOWSEAL_GOOGLE
--hostlist=$GOOGLE_HOSTS
$(flowseal_common_hosts)
--dpi-desync=fake
--dpi-desync-repeats=$udp_repeats
--dpi-desync-fake-quic=$FAKE_DIR/quic_initial_www_google_com.bin
$(flowseal_discord_udp_block "$discord_udp_mode")
--new
--filter-tcp=2053,2083,2087,2096,8443
--hostlist-domains=discord.media
$discord_opts
--new
--filter-tcp=443
--hostlist=$FLOWSEAL_GOOGLE
--ip-id=zero
$google_opts
--new
--filter-tcp=80,443
$(flowseal_common_hosts)
$general_opts
EOF
}

flowseal_emit_alt05() {
	label="$1"
	cat <<EOF
--comment=ZTOOL_$label
--filter-udp=443
$(flowseal_common_hosts)
--dpi-desync=fake
--dpi-desync-repeats=6
--dpi-desync-fake-quic=$FAKE_DIR/quic_initial_www_google_com.bin
$(flowseal_discord_udp_block normal)
--new
--filter-l3=ipv4
--filter-tcp=80,443,2053,2083,2087,2096,8443
--dpi-desync=syndata,multidisorder
EOF
}

flowseal_upstream_strategy() {
	label="$1"
	variant="$2"
	udp_repeats=6
	discord_udp_mode=normal
	case "$variant" in
	general)
		discord_opts="$(cat <<EOF
--dpi-desync=multisplit
--dpi-desync-split-seqovl=681
--dpi-desync-split-pos=1
--dpi-desync-split-seqovl-pattern=$FAKE_DIR/tls_clienthello_www_google_com.bin
EOF
)"
		google_opts="$discord_opts"
		general_opts="$(cat <<EOF
--dpi-desync=multisplit
--dpi-desync-split-seqovl=568
--dpi-desync-split-pos=1
--dpi-desync-split-seqovl-pattern=$FAKE_DIR/4pda.bin
EOF
)"
		;;
	alt01)
		discord_opts="$(cat <<EOF
--dpi-desync=fake,fakedsplit
--dpi-desync-repeats=6
--dpi-desync-fooling=ts
--dpi-desync-fakedsplit-pattern=0x00
--dpi-desync-fake-tls=$FAKE_DIR/tls_clienthello_www_google_com.bin
EOF
)"
		google_opts="$discord_opts"
		general_opts="$(cat <<EOF
--dpi-desync=fake,fakedsplit
--dpi-desync-repeats=6
--dpi-desync-fooling=ts
--dpi-desync-fakedsplit-pattern=0x00
--dpi-desync-fake-tls=$FAKE_DIR/stun.bin
--dpi-desync-fake-tls=$FAKE_DIR/tls_clienthello_www_google_com.bin
--dpi-desync-fake-http=$FAKE_DIR/tls_clienthello_max_ru.bin
EOF
)"
		;;
	alt02)
		discord_opts="$(cat <<EOF
--dpi-desync=multisplit
--dpi-desync-split-seqovl=652
--dpi-desync-split-pos=2
--dpi-desync-split-seqovl-pattern=$FAKE_DIR/tls_clienthello_www_google_com.bin
EOF
)"
		google_opts="$discord_opts"
		general_opts="$discord_opts"
		;;
	alt03)
		discord_opts="$(cat <<EOF
--dpi-desync=fake,hostfakesplit
--dpi-desync-fake-tls-mod=rnd,dupsid,sni=www.google.com
--dpi-desync-hostfakesplit-mod=host=www.google.com,altorder=1
--dpi-desync-fooling=ts
EOF
)"
		google_opts="$discord_opts"
		general_opts="$(cat <<EOF
--dpi-desync=fake,hostfakesplit
--dpi-desync-fake-tls-mod=rnd,dupsid,sni=ya.ru
--dpi-desync-hostfakesplit-mod=host=ya.ru,altorder=1
--dpi-desync-fooling=ts
--dpi-desync-fake-http=$FAKE_DIR/tls_clienthello_max_ru.bin
EOF
)"
		;;
	alt04)
		discord_opts="$(cat <<EOF
--dpi-desync=fake,multisplit
--dpi-desync-repeats=6
--dpi-desync-fooling=badseq
--dpi-desync-badseq-increment=1000
--dpi-desync-fake-tls=$FAKE_DIR/tls_clienthello_www_google_com.bin
EOF
)"
		google_opts="$discord_opts"
		general_opts="$(cat <<EOF
--dpi-desync=fake,multisplit
--dpi-desync-repeats=6
--dpi-desync-fooling=badseq
--dpi-desync-badseq-increment=1000
--dpi-desync-fake-tls=$FAKE_DIR/stun.bin
--dpi-desync-fake-tls=$FAKE_DIR/tls_clienthello_www_google_com.bin
--dpi-desync-fake-http=$FAKE_DIR/tls_clienthello_max_ru.bin
EOF
)"
		;;
	alt05)
		flowseal_emit_alt05 "$label"
		return 0
		;;
	alt06)
		discord_opts="$(cat <<EOF
--dpi-desync=multisplit
--dpi-desync-split-seqovl=681
--dpi-desync-split-pos=1
--dpi-desync-split-seqovl-pattern=$FAKE_DIR/tls_clienthello_www_google_com.bin
EOF
)"
		google_opts="$discord_opts"
		general_opts="$discord_opts"
		;;
	alt07)
		discord_opts="$(cat <<EOF
--dpi-desync=multisplit
--dpi-desync-split-pos=2,sniext+1
--dpi-desync-split-seqovl=679
--dpi-desync-split-seqovl-pattern=$FAKE_DIR/tls_clienthello_www_google_com.bin
EOF
)"
		google_opts="$discord_opts"
		general_opts="$discord_opts"
		;;
	alt08)
		discord_opts="$(cat <<EOF
--dpi-desync=fake
--dpi-desync-fake-tls-mod=none
--dpi-desync-repeats=6
--dpi-desync-fooling=badseq
