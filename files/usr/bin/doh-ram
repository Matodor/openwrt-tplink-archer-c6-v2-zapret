#!/bin/sh
set -u

TAG="doh-ram"
DOH_BIN="/tmp/usr/sbin/https-dns-proxy"
DOH_LIB="/tmp/usr/lib"
CF_PORT="5053"
GOOGLE_PORT="5054"

log() {
	logger -t "$TAG" "$*"
	echo "$*"
}

dns_upstream() {
	uci -q delete dhcp.@dnsmasq[0].noresolv || true
	uci -q delete dhcp.@dnsmasq[0].server || true
	uci -q set dhcp.@dnsmasq[0].resolvfile='/tmp/resolv.conf.d/resolv.conf.auto'
	uci -q commit dhcp
	/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
}

dns_doh() {
	uci -q set dhcp.@dnsmasq[0].noresolv='1'
	uci -q delete dhcp.@dnsmasq[0].server || true
	uci -q add_list dhcp.@dnsmasq[0].server="127.0.0.1#$CF_PORT"
	uci -q add_list dhcp.@dnsmasq[0].server="127.0.0.1#$GOOGLE_PORT"
	uci -q commit dhcp
	/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
}

wait_network() {
	i=0
	while [ "$i" -lt 30 ]; do
		[ -s /tmp/resolv.conf.d/resolv.conf.auto ] && ip route 2>/dev/null | grep -q '^default ' && return 0
		i=$((i + 1))
		sleep 2
	done
	return 1
}

install_ram() {
	[ -x "$DOH_BIN" ] && [ -e "$DOH_LIB/libcares.so.2" ] && [ -e "$DOH_LIB/libev.so.4" ] && return 0
	wait_network || {
		log "network is not ready; leaving upstream DNS"
		return 1
	}
	opkg update >/tmp/doh-ram-opkg-update.log 2>&1 || {
		log "opkg update failed; leaving upstream DNS"
		return 1
	}
	opkg -d ram install https-dns-proxy >/tmp/doh-ram-opkg-install.log 2>&1 || {
		log "RAM install failed; leaving upstream DNS"
		return 1
	}
}

start_proxy() {
	killall https-dns-proxy >/dev/null 2>&1 || true
	LD_LIBRARY_PATH="$DOH_LIB" "$DOH_BIN" -d -a 127.0.0.1 -p "$CF_PORT" -b 1.1.1.1,1.0.0.1 -r https://cloudflare-dns.com/dns-query -4 -u nobody -g nogroup -l /tmp/https-dns-proxy-cf.log
	LD_LIBRARY_PATH="$DOH_LIB" "$DOH_BIN" -d -a 127.0.0.1 -p "$GOOGLE_PORT" -b 8.8.8.8,8.8.4.4 -r https://dns.google/dns-query -4 -u nobody -g nogroup -l /tmp/https-dns-proxy-google.log
	sleep 2
	nslookup openwrt.org "127.0.0.1:$CF_PORT" >/dev/null 2>&1 || return 1
}

start() {
	dns_upstream
	install_ram || return 1
	if start_proxy; then
		dns_doh
		log "DoH enabled on 127.0.0.1#$CF_PORT and 127.0.0.1#$GOOGLE_PORT"
	else
		dns_upstream
		log "DoH proxy failed health check; restored upstream DNS"
		return 1
	fi
}

stop() {
	killall https-dns-proxy >/dev/null 2>&1 || true
	dns_upstream
	log "DoH stopped; restored upstream DNS"
}

status() {
	if pidof https-dns-proxy >/dev/null 2>&1; then
		echo "running"
		uci show dhcp 2>/dev/null | grep -E 'noresolv|server' || true
		return 0
	fi
	echo "stopped"
	return 1
}

case "${1:-start}" in
	start) start ;;
	stop) stop ;;
	restart) stop; start ;;
	status) status ;;
	*) echo "usage: doh-ram start|stop|restart|status" >&2; exit 2 ;;
esac
